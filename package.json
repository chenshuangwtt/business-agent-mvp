{
  "name": "business-agent-mvp",
  "version": "1.0.0",
  "description": "企业经营分析 Agent MVP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:ui": "cd frontend && pnpm dev",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "build:ui": "cd frontend && pnpm build",
    "build:all": "pnpm run build && pnpm run build:ui",
    "check": "pnpm run typecheck && pnpm --dir frontend run typecheck && pnpm run test",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.73.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
